import os
import sys
import shutil
import subprocess
from pathlib import Path

# ==============================================================================
# 1. CONFIGURACIÓN DEL ENTORNO Y DESCARGA DE DATOS
# ==============================================================================

# Detectar si estamos en Google Colab
IN_COLAB = "google.colab" in sys.modules or os.path.exists("/content")
DATA_ROOT_OVERRIDE = None

if IN_COLAB:
    print("📦 Entorno Google Colab detectado. Iniciando configuración...")
    
    # Actualizar la API de Kaggle
    subprocess.run([sys.executable, "-m", "pip", "install", "kaggle", "--upgrade", "-q"], check=True)

    # Gestión de credenciales kaggle.json
    from google.colab import files
    kaggle_path = Path('/root/.kaggle/kaggle.json')
    
    if not kaggle_path.exists():
        print("🔑 Sube tu archivo kaggle.json (lo encuentras en Kaggle -> Settings -> API):")
        uploaded = files.upload()
        if 'kaggle.json' in uploaded:
            kaggle_path.parent.mkdir(parents=True, exist_ok=True)
            shutil.move('kaggle.json', str(kaggle_path))
            kaggle_path.chmod(0o600)
            print("✓ Credenciales configuradas correctamente.")
    else:
        print("✓ Credenciales ya detectadas en /root/.kaggle")

    # Descarga del dataset Landslide4Sense
    print("🛰️ Descargando dataset... Esto puede demorar un par de minutos.")
    try:
        # Usamos el dataset oficial lxrzp/landslide4sense
        subprocess.run(
            ["kaggle", "datasets", "download", "-d", "lxrzp/landslide4sense",
             "-p", "/content/", "--unzip"],
            check=True
        )
        print("✓ Descarga y descompresión completada.")
    except subprocess.CalledProcessError as e:
        print(f"❌ Error en la descarga: {e}")
        print("Tip: Verifica que tu cuenta de Kaggle tenga acceso al dataset.")

    # Localizar automáticamente dónde quedó la carpeta 'TrainData'
    for _root, _dirs, _ in os.walk('/content'):
        if 'TrainData' in _dirs:
            DATA_ROOT_OVERRIDE = _root
            break
else:
    print('💻 Ejecutando en entorno local.')

# ==============================================================================
# 2. VERIFICACIÓN DE RUTAS Y ESTRUCTURA
# ==============================================================================

if DATA_ROOT_OVERRIDE:
    DATA_ROOT = Path(DATA_ROOT_OVERRIDE)
else:
    # Búsqueda de candidatos en entorno local
    _cwd = Path.cwd()
    _candidates = [_cwd / ".." / "data", _cwd / "data", _cwd.parent, _cwd]
    DATA_ROOT = next((c.resolve() for c in _candidates if (c / "TrainData" / "img").exists()), None)

if DATA_ROOT is None or not (DATA_ROOT / "TrainData").exists():
    print("❌ ERROR: No se encontró la carpeta 'TrainData'.")
else:
    print(f"\n📂 DATA_ROOT fijado en: {DATA_ROOT}")
    print("Estructura de archivos encontrada:")
    for part in ["TrainData", "ValidData", "TestData"]:
        img_p = DATA_ROOT / part / "img"
        mask_p = DATA_ROOT / part / "mask"
        n_imgs = len(list(img_p.glob("*.h5"))) if img_p.exists() else 0
        n_masks = len(list(mask_p.glob("*.h5"))) if mask_p.exists() else 0
        status = "✓" if n_imgs > 0 else "✗"
        print(f"  {status} {part:<10} | Img: {n_imgs:>4} | Mask: {n_masks:>4}")

# ==============================================================================
# 3. INSTALACIÓN DE DEPENDENCIAS Y VERIFICACIÓN TÉCNICA
# ==============================================================================

packages = ["timm", "segmentation-models-pytorch", "h5py", "pyyaml"]

if IN_COLAB:
    print("\n🛠️ Instalando librerías adicionales...")
    subprocess.run([sys.executable, "-m", "pip", "install"] + packages + ["-q"], check=True)

import torch
import h5py
import numpy as np
import matplotlib.pyplot as plt

print(f"\n✅ Verificación técnica:")
print(f"  - PyTorch versión: {torch.__version__}")
print(f"  - Dispositivo: {'GPU 🔥' if torch.cuda.is_available() else 'CPU ❄️'}")
if torch.cuda.is_available():
    print(f"  - GPU detectada: {torch.cuda.get_device_name(0)}")

# ==============================================================================
# 4. VISUALIZACIÓN DE PRUEBA (DATA CHECK)
# ==============================================================================

try:
    img_list = sorted((DATA_ROOT / "TrainData" / "img").glob("*.h5"))
    if img_list:
        with h5py.File(img_list[0], 'r') as f:
            data = f['img'][:] # Cargar matriz (128, 128, 14)
        
        print(f"\n🖼️ Visualizando patch: {img_list[0].name}")
        fig, axes = plt.subplots(1, 3, figsize=(15, 5))
        
        # Canales: 0 (Rojo), 7 (SAR VV), 9 (DEM)
        ch_idx = [0, 7, 9]
        ch_names = ['Banda Roja (Opt)', 'SAR VV (Radar)', 'DEM (Elevación)']
        
        for i, (idx, name) in enumerate(zip(ch_idx, ch_names)):
            im = axes[i].imshow(data[:, :, idx], cmap='viridis' if idx==9 else 'gray')
            axes[i].set_title(name)
            axes[i].axis('off')
            plt.colorbar(im, ax=axes[i], fraction=0.046, pad=0.04)
        
        plt.tight_layout()
        plt.show()
    else:
        print("\n⚠️ No hay archivos .h5 para visualizar.")
except Exception as e:
    print(f"\n⚠️ Error al intentar visualizar los datos: {e}")

print("\n🚀 ¡Todo listo para el Notebook 01!")
