    "<a href=\"https://colab.research.google.com/github/apmontesp/Landslides_-Applied-ML-Course/blob/main/notebooks/03_baseline_rf.ipynb\" target=\"_parent\"><img src=\"https://colab.research.google.com/assets/colab-badge.svg\" alt=\"Open In Colab\"/></a>\n",
    "\n",
    "# Notebook 03: Baseline Final con Análisis para Tesis\n",
    "**Proyecto:** Detección de deslizamientos mediante IA | Universidad EAFIT\n",
    "\n",
    "Este notebook integra el entrenamiento de Random Forest con métricas avanzadas: Importancia de Variables, Matriz de Confusión y Curva ROC."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from google.colab import drive\n",
    "import os, h5py\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from pathlib import Path\n",
    "from tqdm.auto import tqdm\n",
    "from skimage.feature import hog\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "from sklearn.model_selection import StratifiedKFold\n",
    "from sklearn.metrics import f1_score, confusion_matrix, ConfusionMatrixDisplay, roc_curve, auc\n",
    "\n",
    "drive.mount('/content/drive')\n",
    "\n",
    "base_path = Path('/content/drive/MyDrive/Landslide4Sense')\n",
    "img_dirs = list(base_path.glob('**/TrainData/img'))\n",
    "\n",
    "if img_dirs:\n",
    "    train_img_dir = img_dirs[0]\n",
    "    train_mask_dir = train_img_dir.parent / \"mask\"\n",
    "    img_list = sorted(list(train_img_dir.glob(\"*.h5\")))\n",
    "    mask_list = sorted(list(train_mask_dir.glob(\"*.h5\")))\n",
    "    print(f\"✅ Datos listos: {len(img_list)} muestras detectadas.\")\n",
    "else:\n",
    "    print(\"❌ ERROR: Verifica la ruta de los datos en Drive.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "N_SAMPLES = 1000 \n",
    "X, y = [], []\n",
    "\n",
    "for i in tqdm(range(min(N_SAMPLES, len(img_list))), desc=\"Procesando parches\"):\n",
    "    with h5py.File(img_list[i], \"r\") as hf:\n",
    "        patch = hf[list(hf.keys())[0]][()]\n",
    "    with h5py.File(mask_list[i], \"r\") as hf:\n",
    "        mask = hf[list(hf.keys())[0]][()]\n",
    "    \n",
    "    # Normalización compatible con NumPy 2.0\n",
    "    rgb = patch[:,:,[3,2,1]]\n",
    "    rgb_norm = ((rgb - np.min(rgb)) / (np.ptp(rgb) + 1e-8) * 255).astype(\"uint8\")\n",
    "    \n",
    "    # Características: HOG + Pendiente (Banda 13)\n",
    "    feats_hog = hog(rgb_norm, pixels_per_cell=(16,16), cells_per_block=(2,2), channel_axis=-1, feature_vector=True)\n",
    "    avg_slope = np.mean(patch[:,:,12])\n",
    "    \n",
    "    X.append(np.hstack([feats_hog, avg_slope]))\n",
    "    y.append(int(np.max(mask) > 0))\n",
    "\n",
    "X, y = np.array(X), np.array(y)\n",
    "print(f\"✓ Dataset preparado: {X.shape}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "skf = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\n",
    "f1_scores = []\n",
    "\n",
    "for fold, (t_idx, v_idx) in enumerate(skf.split(X, y)):\n",
    "    rf = RandomForestClassifier(n_estimators=100, n_jobs=-1, random_state=42)\n",
    "    rf.fit(X[t_idx], y[t_idx])\n",
    "    \n",
    "    preds = rf.predict(X[v_idx])\n",
    "    f1 = f1_score(y[v_idx], preds)\n",
    "    f1_scores.append(f1)\n",
    "    print(f\"Fold {fold+1}: F1 = {f1:.4f}\")\n",
    "\n",
    "print(f\"\\n🚀 BASELINE FINAL (F1): {np.mean(f1_scores):.4f}\")\n",
    "\n",
    "# --- BLOQUE DE GRÁFICAS Y ANÁLISIS ---\n",
    "fig, ax = plt.subplots(1, 3, figsize=(20, 6))\n",
    "\n",
    "# 1. Importancia de Características\n",
    "importances = rf.feature_importances_\n",
    "indices = np.argsort(importances)[-15:]\n",
    "ax[0].barh(range(len(indices)), importances[indices], color='skyblue')\n",
    "ax[0].set_yticks(range(len(indices)))\n",
    "ax[0].set_yticklabels([f'HOG_{i}' if i < X.shape[1]-1 else 'SLOPE (B13)' for i in indices])\n",
    "ax[0].set_title(\"Top 15 Importancia\")\n",
    "\n",
    "# 2. Matriz de Confusión\n",
    "cm = confusion_matrix(y[v_idx], preds)\n",
    "disp = ConfusionMatrixDisplay(cm, display_labels=['No Desliz.', 'Desliz.'])\n",
    "disp.plot(cmap='Blues', ax=ax[1], colorbar=False)\n",
    "ax[1].set_title(\"Matriz de Confusión\")\n",
    "\n",
    "# 3. Curva ROC\n",
    "y_probs = rf.predict_proba(X[v_idx])[:, 1]\n",
    "fpr, tpr, _ = roc_curve(y[v_idx], y_probs)\n",
    "ax[2].plot(fpr, tpr, color='darkorange', lw=2, label=f'AUC = {auc(fpr, tpr):.3f}')\n",
    "ax[2].plot([0, 1], [0, 1], color='navy', lw=1, linestyle='--')\n",
    "ax[2].set_title(\"Curva ROC\")\n",
    "ax[2].legend(loc=\"lower right\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  }
 ],
