# 0. Configuración inicial
from google.colab import drive
drive.mount('/content/drive', force_remount=False)
print('✔ Drive montado')

DRIVE_PATH = '/content/drive/MyDrive/Landslide_ML'

import os, sys
import h5py
import numpy as np
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches
import seaborn as sns
import warnings
import shap
from pathlib import Path
from scipy.ndimage import uniform_filter
from sklearn.ensemble import RandomForestClassifier
from sklearn.model_selection import StratifiedKFold, cross_val_score, train_test_split
from sklearn.metrics import f1_score, roc_auc_score
from tqdm.notebook import tqdm

warnings.filterwarnings('ignore')
%matplotlib inline

ROOT = Path(DRIVE_PATH)
IMG_DIR = ROOT / 'TrainData' / 'img'
MASK_DIR = ROOT / 'TrainData' / 'mask'
OUT_DIR = ROOT / 'results' / 'analisis_avanzado'
OUT_DIR.mkdir(parents=True, exist_ok=True)

# 1. Parámetros y Funciones de Procesamiento
CHANNEL_NAMES = [
    'S2-B2 Azul','S2-B3 Verde','S2-B4 Rojo','S2-B8 NIR','S2-B8A NIR-A',
    'S2-B11 SWIR1','S2-B12 SWIR2','S1-VV SAR','S1-VH SAR',
    'ALOS DEM','ALOS Pendiente','S2-B5 RedEdge1','S2-B6 RedEdge2','S2-B7 RedEdge3',
]
CHANNEL_GROUPS = {
    'S2 Optico':[0,1,2,3,4,5,6],'SAR':[7,8],'DEM':[9,10],'Red-Edge':[11,12,13],
}
GROUP_COLORS = {
    'S2 Optico':'#2E5FA3','SAR':'#D97706','DEM':'#16A34A','Red-Edge':'#9333EA',
}

# Parámetros Geotécnicos (Tesis EAFIT)
PHI_DEG=28.0; COHESION=12.0; GAMMA=18.0; Z_PROF=2.0; U_PRESION=5.0
N_SAMPLES=500; N_ESTIMATORS=200; SEED=42

def compute_twi(dem, slope, kernel=9):
    area = uniform_filter(dem.astype(np.float64), size=kernel) + 1e-6
    slope_rad = np.deg2rad(np.clip(slope*60.0, 0.1, 89.9))
    return np.log(area/np.tan(slope_rad)).astype(np.float32)

def compute_fos(slope):
    slope_rad = np.deg2rad(np.clip(slope*60.0, 0.1, 89.9))
    cos_b, sin_b = np.cos(slope_rad), np.sin(slope_rad)
    tan_phi = np.tan(np.deg2rad(PHI_DEG))
    fs_num = COHESION + (GAMMA*Z_PROF*cos_b**2 - U_PRESION)*tan_phi
    fs_den = GAMMA*Z_PROF*sin_b*cos_b + 1e-6
    return np.clip(fs_num/fs_den, 0.0, 5.0).astype(np.float32)

def physics_features(patch):
    dem, slope, vh = patch[:,:,9], patch[:,:,10], patch[:,:,8]
    twi, fos = compute_twi(dem, slope), compute_fos(slope)
    # FIX NumPy 2.0: Usar np.ptp()
    vh_n = (vh - vh.min()) / (np.ptp(vh) + 1e-8)
    twi_n = (twi - twi.min()) / (np.ptp(twi) + 1e-8)
    return {
        'twi': twi, 'fos': fos, 'shi': (vh_n/(twi_n+0.1)).astype(np.float32),
        'twi_mean': float(twi.mean()), 'fos_min': float(fos.min()),
        'fos_mean': float(fos.mean()), 'area_inest': float((fos<1.0).mean()),
        'shi_mean': float((vh_n/(twi_n+0.1)).mean()), 'twi_std': float(twi.std()),
        'fos_p25': float(np.percentile(fos, 25)), 'ero_mean': float((slope*60*np.std(vh)).mean())
    }

def extract_features(patch):
    eps = 1e-8
    nir, rojo, verde, azul = patch[:,:,3], patch[:,:,2], patch[:,:,1], patch[:,:,0]
    vv, vh = patch[:,:,7], patch[:,:,8]
    ndvi = (nir-rojo)/(nir+rojo+eps)
    ndwi = (verde-nir)/(verde+nir+eps)
    sar_cr = vh/(vv+eps)
    evi = 2.5*(nir-rojo)/(nir+6*rojo-7.5*azul+1+eps)
    return np.concatenate([patch.mean(axis=(0,1)), patch.std(axis=(0,1)), 
                           [ndvi.mean(), ndwi.mean(), sar_cr.mean(), evi.mean()]]).astype(np.float32)

# 2. Carga del Dataset
img_files = sorted(IMG_DIR.glob('*.h5'))
rng = np.random.default_rng(SEED)
chosen = sorted(rng.choice(len(img_files), size=min(N_SAMPLES, len(img_files)), replace=False))

X_list, y_list, patches, masks = [], [], [], []
for i in tqdm(chosen, desc='Cargando datos'):
    img_f = img_files[i]
    mask_f = MASK_DIR / img_f.name.replace('image_', 'mask_')
    if not mask_f.exists(): continue
    with h5py.File(img_f, 'r') as f:
        patch = f[list(f.keys())[0]][()].astype(np.float32)
    with h5py.File(mask_f, 'r') as f:
        mask = f[list(f.keys())[0]][()].astype(np.uint8)
    X_list.append(extract_features(patch))
    y_list.append(int(mask.max() > 0))
    patches.append(patch); masks.append(mask)

X, y = np.stack(X_list), np.array(y_list)
feature_names = [f'mu_{n}' for n in CHANNEL_NAMES] + [f'sg_{n}' for n in CHANNEL_NAMES] + ['NDVI','NDWI','SAR-CR','EVI']

# 3. Entrenamiento y SHAP (FIX Dimensiones)
rf = RandomForestClassifier(n_estimators=N_ESTIMATORS, class_weight='balanced', n_jobs=-1, random_state=SEED)
rf.fit(X, y)

explainer = shap.TreeExplainer(rf)
sv_raw = explainer.shap_values(X[:200])
# Seleccionar clase 1 (deslizamiento) y manejar arreglo 3D
sv = sv_raw[:,:,1] if (not isinstance(sv_raw, list) and len(sv_raw.shape)==3) else (sv_raw[1] if isinstance(sv_raw, list) else sv_raw)

mean_abs = np.abs(sv).mean(axis=0)
order = [int(i) for i in np.argsort(mean_abs)[::-1][:20]]

# 4. Visualización de Resultados
def feat_color(name):
    n = name.upper().replace(' ','')
    for g, idxs in CHANNEL_GROUPS.items():
        for i in idxs:
            if CHANNEL_NAMES[i].upper().replace(' ','') in n: return GROUP_COLORS[g]
    return '#6B7280'

fig, ax = plt.subplots(figsize=(10, 7))
ax.barh(range(len(order)), mean_abs[order], color=[feat_color(feature_names[i]) for i in order])
ax.set_yticks(range(len(order)))
ax.set_yticklabels([feature_names[i] for i in order])
ax.invert_yaxis()
ax.set_title('Importancia de Variables (SHAP) - Clase: Deslizamiento')
plt.show()

# Visualización Parche Físico (FIX NumPy 2.0)
ex_idx = next(i for i, m in enumerate(masks) if m.max() > 0)
p, m = patches[ex_idx], masks[ex_idx]
ph = physics_features(p)
rgb_data = p[:,:,[2,1,0]]
rgb = np.clip((rgb_data - rgb_data.min()) / (np.ptp(rgb_data) + 1e-8), 0, 1)

plt.figure(figsize=(15, 5))
plt.subplot(131); plt.imshow(rgb); plt.title('RGB'); plt.axis('off')
plt.subplot(132); plt.imshow(ph['fos'], cmap='RdYlGn'); plt.title('Factor de Seguridad'); plt.axis('off')
plt.subplot(133); plt.imshow(m, cmap='Reds'); plt.title('Mascara Real'); plt.axis('off')
plt.tight_layout(); plt.show()

print("✔ Proceso completado sin errores de NumPy ni SHAP.")
