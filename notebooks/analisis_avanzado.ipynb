# 0. Configuración inicial y Montaje de Drive
from google.colab import drive
drive.mount('/content/drive', force_remount=False)

import os, sys, h5py, warnings, shap
import numpy as np
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches
from pathlib import Path
from scipy.ndimage import uniform_filter
from sklearn.ensemble import RandomForestClassifier
from sklearn.model_selection import cross_val_score
from tqdm.notebook import tqdm

warnings.filterwarnings('ignore')
%matplotlib inline

# --- CONFIGURA TU RUTA AQUÍ ---
DRIVE_PATH = '/content/drive/MyDrive/Landslide_ML'
ROOT = Path(DRIVE_PATH)
IMG_DIR, MASK_DIR = ROOT/'TrainData'/'img', ROOT/'TrainData'/'mask'
OUT_DIR = ROOT/'results'/'analisis_avanzado'
OUT_DIR.mkdir(parents=True, exist_ok=True)

# 1. Parámetros Geotécnicos (Tesis Lisa - EAFIT)
PHI_DEG, COHESION, GAMMA = 28.0, 12.0, 18.0
Z_PROF, U_PRESION = 2.0, 5.0
CHANNEL_NAMES = ['S2-B2 Azul','S2-B3 Verde','S2-B4 Rojo','S2-B8 NIR','S2-B8A NIR-A','S2-B11 SWIR1','S2-B12 SWIR2','S1-VV SAR','S1-VH SAR','ALOS DEM','ALOS Pendiente','S2-B5 RedEdge1','S2-B6 RedEdge2','S2-B7 RedEdge3']
GROUP_COLORS = {'S2 Optico':'#2E5FA3','SAR':'#D97706','DEM':'#16A34A','Red-Edge':'#9333EA'}
CHANNEL_GROUPS = {'S2 Optico':[0,1,2,3,4,5,6],'SAR':[7,8],'DEM':[9,10],'Red-Edge':[11,12,13]}

# 2. Funciones de Cálculo (Compatibles con NumPy 2.0)
def compute_fos(slope):
    slope_rad = np.deg2rad(np.clip(slope*60.0, 0.1, 89.9))
    tan_phi = np.tan(np.deg2rad(PHI_DEG))
    fs_num = COHESION + (GAMMA*Z_PROF*np.cos(slope_rad)**2 - U_PRESION)*tan_phi
    fs_den = GAMMA*Z_PROF*np.sin(slope_rad)*np.cos(slope_rad) + 1e-6
    return np.clip(fs_num/fs_den, 0.0, 5.0).astype(np.float32)

def physics_features(patch):
    dem, slope, vh = patch[:,:,9], patch[:,:,10], patch[:,:,8]
    fos = compute_fos(slope)
    vh_n = (vh - vh.min()) / (np.ptp(vh) + 1e-8) # Fix NumPy 2.0
    return {'fos': fos, 'fos_mean': float(fos.mean()), 'fos_min': float(fos.min())}

def extract_features(patch):
    nir, rojo = patch[:,:,3], patch[:,:,2]
    ndvi = (nir-rojo)/(nir+rojo+1e-8)
    return np.concatenate([patch.mean(axis=(0,1)), patch.std(axis=(0,1)), [ndvi.mean()]]).astype(np.float32)

# 3. Carga y Procesamiento
img_files = sorted(IMG_DIR.glob('*.h5'))
X_list, y_list, patches, masks = [], [], [], []
for i in tqdm(range(min(200, len(img_files))), desc='Procesando'):
    img_f = img_files[i]
    mask_f = MASK_DIR / img_f.name.replace('image_', 'mask_')
    if not mask_f.exists(): continue
    with h5py.File(img_f, 'r') as f: patch = f[list(f.keys())[0]][()].astype(np.float32)
    with h5py.File(mask_f, 'r') as f: mask = f[list(f.keys())[0]][()].astype(np.uint8)
    X_list.append(extract_features(patch)); y_list.append(int(mask.max() > 0))
    patches.append(patch); masks.append(mask)

X, y = np.stack(X_list), np.array(y_list)
feature_names = [f'mu_{n}' for n in CHANNEL_NAMES] + [f'sg_{n}' for n in CHANNEL_NAMES] + ['NDVI']

# 4. RF y SHAP (Fix Dimensiones Clase 1)
rf = RandomForestClassifier(n_estimators=100, class_weight='balanced', n_jobs=-1, random_state=42)
rf.fit(X, y)
explainer = shap.TreeExplainer(rf)
sv_raw = explainer.shap_values(X[:100])
sv = sv_raw[:,:,1] if (not isinstance(sv_raw, list) and len(sv_raw.shape)==3) else (sv_raw[1] if isinstance(sv_raw, list) else sv_raw)

# 5. Visualización Final
mean_abs = np.abs(sv).mean(axis=0)
order = [int(i) for i in np.argsort(mean_abs)[::-1][:15]]
plt.figure(figsize=(10, 6))
plt.barh(range(len(order)), mean_abs[order], color='#2E5FA3')
plt.yticks(range(len(order)), [feature_names[i] for i in order])
plt.gca().invert_yaxis()
plt.title('Top 15 Variables - Importancia SHAP')
plt.show()

print("✔ Notebook reconstruido y ejecutado con éxito.")
